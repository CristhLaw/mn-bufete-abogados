@startuml
left to right direction
!theme bluegray

skinparam footerFontColor black
title <size:20><b>Caso de uso "CU04 - Gestionar Agenda"</b></size>

' =====================================================
' ACTORES
' =====================================================

actor "Abogado" as abogado
actor "Secretaria" as secretaria

' =====================================================
' SISTEMA
' =====================================================

rectangle "IURIS - Sistema Integral"{

    usecase "◉\n<size:18><b>CU04</b></size>\nGestionar Agenda" as UC_Agenda

    usecase "🔐\nAutenticar Usuario" as UC_Auth
    usecase "📅\nProgramar Audiencias\ny Citas" as UC_Programar
    usecase "⚡\nValidar disponibilidad\ny conflictos" as UC_Validar
    usecase "⚠\nMostrar\nMensaje de error" as UC_error
}

' =====================================================
' RELACIONES
' =====================================================

abogado --> UC_Agenda : Accede
secretaria --> UC_Agenda : Accede

UC_Agenda .> UC_Auth : <<include>>
UC_Agenda .> UC_Programar : <<include>>
UC_Agenda .> UC_Validar : <<include>>

UC_error .> UC_Agenda : <<extend>>

' =====================================================
' LEYENDA PROFESIONAL
' =====================================================

legend right
|= <b><size:14>LEYENDA GENERAL</size></b> |= |

|= <b>Símbolo</b> |= <b>Descripción</b> |

| ◉ | Caso de uso principal |
| 🔐 | Verificación de identidad |
| 📅 | Registro de eventos |
| ⚡ | Resolución de conflictos |
| ⚠ | Flujo alternativo de error |

|= <b>Relación</b> |= <b>Significado</b> |

| ─────► | Asociación actor → caso de uso |
| · · · ► | Dependencia UML |
| <<include>> | Flujo obligatorio |
| <<extend>> | Flujo alternativo/excepcional |

endlegend

' =====================================================
' FOOTER
' =====================================================

footer
<b>IURIS - LexTech Solutions S.A.C.</b>
Diagramas UML - Casos de Uso
PlantUML %version()
endfooter

@enduml