@startuml
left to right direction
!theme bluegray
skinparam footerFontColor black
title Caso de uso "CU01 - Gestionar Sesión"

' =====================================================
' ACTOR
' =====================================================
actor "Cliente" as cliente

' =====================================================
' SISTEMA
' =====================================================
rectangle "IURIS - Sistema Integral" {
    usecase "◉\nsize:18CU01\nGestionar Sesión" as UC_Sesion
    usecase "🔑\nValidar\nCredenciales" as UC_Validar
    usecase "🔐\nGenerar\nToken JWT" as UC_JWT
    usecase "⚠\nMostrar\nMensaje de Error" as UC_Error
}

' =====================================================
' RELACIONES
' =====================================================
cliente --> UC_Sesion

' Relaciones de inclusión (Flujo obligatorio)
UC_Sesion ..> UC_Validar : <<include>>
UC_Sesion ..> UC_JWT : <<include>>

' Manejo de excepciones
UC_Error ..> UC_Sesion : <<extend>>

legend right
|= Símbolo |= Descripción |
| ◉ | Caso de uso principal |
| 🔑 | Validación de credenciales |
| 🔐 | Emisión de Token JWT |
| ⚠ | Flujo de error |
|= Relación |= Significado |
| ─────► | Asociación actor → CU |
| <> | Flujo obligatorio |
| <> | Flujo excepcional |
endlegend

footer IURIS - LexTech Solutions S.A.C.
@enduml