@startuml CU-AB-09-gestionar-citas-audiencias

left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor "Abogado Principal" as AB

rectangle "MS Agenda y Audiencias" {
  usecase "CU-AB-09\nGestionar Citas y Audiencias" as CU09
}

AB --> CU09

note right of CU09
  DisponibilidadValidator
  valida disponibilidad con
  24h de anticipación
end note

@enduml