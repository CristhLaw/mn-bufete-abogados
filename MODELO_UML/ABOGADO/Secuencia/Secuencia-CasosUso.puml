@startuml
actor "Abogado" as Abogado
participant "App Web" as Web
participant "CasoController" as MSCasos
database "Base de Datos" as BD

Abogado -> Web: Clic en "Cerrar Caso" (UC5)
Web -> MSCasos: POST /api/casos/{id}/cerrar
activate MSCasos

MSCasos -> BD: Consultar si existe Resolución (UC4)
activate BD
BD --> MSCasos: Resultado de consulta
deactivate BD

alt Sin Resolución Previa
    MSCasos --> Web: 400 Bad Request
    Web --> Abogado: Muestra error: "Debe registrar una resolución primero"
else Resolución Existe
    MSCasos -> BD: Update CasoLegal set estado = 'CERRADO'
    activate BD
    BD --> MSCasos: Actualización exitosa
    deactivate BD

    MSCasos --> Web: 200 OK
    Web --> Abogado: Muestra mensaje: "Caso cerrado exitosamente"
end

deactivate MSCasos
@enduml