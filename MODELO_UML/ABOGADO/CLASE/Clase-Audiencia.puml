@startuml
skinparam classAttributeIconSize 0
hide empty members

class Abogado {
  - idAbogado: UUID
}

class Cliente {
  - idCliente: UUID
}

class Audiencia {
  - idAudiencia: UUID
  - fechaHora: DateTime
  - enlaceVirtual: String
  - estado: EstadoAudiencia
  + agendar(): void
  + reprogramar(nuevaFecha: DateTime): void
  + cancelar(): void
}

class DisponibilidadValidator {
  + validar24Horas(fecha: DateTime): Boolean
  + verificarCruce(idAbogado: UUID, fecha: DateTime): Boolean
}

enum EstadoAudiencia {
  PROGRAMADA
  REPROGRAMADA
  CANCELADA
  REALIZADA
}

Abogado "1" -- "0..*" Audiencia : gestiona >
Cliente "1" -- "0..*" Audiencia : asiste a >
Audiencia ..> DisponibilidadValidator : validada por >
Audiencia -> EstadoAudiencia : tiene >
@enduml